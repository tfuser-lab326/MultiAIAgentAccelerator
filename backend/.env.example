# =============================================================================
# Prior Authorization Review — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# This file configures the FastAPI ORCHESTRATOR only.
# Note: the four MAF agent containers (clinical, coverage, compliance, synthesis)
#       read their own env vars — set those in docker-compose.yml or agent.yaml.
#
# For Azure deployment (azd up), credentials are set via azd env set.
# The .env file is gitignored and will NOT be committed.
# =============================================================================

# ---------------------------------------------------------------------------
# Hosted agent — Docker Compose local dev (REQUIRED for: docker-compose up)
# ---------------------------------------------------------------------------
# In docker-compose.yml these are already hardcoded to Docker service names;
# no action needed for local docker-compose up.
#
# Uncomment to override, e.g. when running the backend process directly
# (outside Docker) but agents are running inside docker-compose:
# HOSTED_AGENT_CLINICAL_URL=http://localhost:8001
# HOSTED_AGENT_COVERAGE_URL=http://localhost:8002
# HOSTED_AGENT_COMPLIANCE_URL=http://localhost:8003
# HOSTED_AGENT_SYNTHESIS_URL=http://localhost:8004
#
# HOSTED_AGENT_TIMEOUT_SECONDS=180

# ---------------------------------------------------------------------------
# Foundry Hosted Agents mode (REQUIRED for: azd up / production)
# ---------------------------------------------------------------------------
# When AZURE_AI_PROJECT_ENDPOINT is set and HOSTED_AGENT_*_URL is empty,
# the backend routes requests through Foundry Agent Service instead of
# direct HTTP.  Credentials come from DefaultAzureCredential (no token needed).
#
# For Azure deployment (azd up), these are injected automatically by Bicep.
# Set manually ONLY when testing locally against a Foundry project:
#
# AZURE_AI_PROJECT_ENDPOINT=https://<foundry-account>.services.ai.azure.com/api/projects/<project-name>
# HOSTED_AGENT_CLINICAL_NAME=clinical-reviewer-agent
# HOSTED_AGENT_COVERAGE_NAME=coverage-assessment-agent
# HOSTED_AGENT_COMPLIANCE_NAME=compliance-agent
# HOSTED_AGENT_SYNTHESIS_NAME=synthesis-agent

# ---------------------------------------------------------------------------
# Frontend CORS origin
# ---------------------------------------------------------------------------
# For local dev with Next.js dev server: http://localhost:3000
# For Docker Compose: set automatically in docker-compose.yml
# For Azure: set automatically by Bicep
FRONTEND_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------------------
# Azure Application Insights (optional — enables OpenTelemetry tracing)
# ---------------------------------------------------------------------------
# Get from Azure Portal → Application Insights → Overview → Connection String
# For Azure deployment (azd up), this is set automatically by Bicep.
# APPLICATION_INSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...;LiveEndpoint=...

# ---------------------------------------------------------------------------
# Logging level (DEBUG | INFO | WARNING | ERROR). Defaults to INFO for prod.
# Set to DEBUG locally for verbose orchestrator/agent traces.
# ---------------------------------------------------------------------------
# LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# OpenTelemetry sensitive-data capture (LOCAL DEV ONLY — DO NOT enable in cloud)
# ---------------------------------------------------------------------------
# When true, prompts, completions, and tool-call arguments are attached to
# gen_ai.* spans. This solution processes PHI (patient identifiers, ICD-10s,
# clinical notes), so leave this UNSET for any shared, staging, or production
# environment. Honored by both the backend (azure-monitor-opentelemetry) and
# every agent host (azure-ai-agentserver). Default: false.
# ENABLE_OTEL_SENSITIVE_DATA=false
